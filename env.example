# TrustGate Environment Configuration
# Copy this file to .env and fill in the required values.

# Base Mainnet RPC URL (Used by ccp-client.js for settlement execution)
RPC_URL=https://mainnet.base.org

# CCP Escrow Contract Address
ESCROW_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# API Configuration
PORT=3000
NODE_ENV=development

# ZK-Circuit Configuration
CIRCUIT_VERIFICATION_KEY_PATH=./circuits/verification_key.json
